  }
{% endstyle %}

<s-text-block
  class="s-text-block"
  {% if request.visual_preview_mode %}
    style="background-color: #fff;"
  {% endif %}
>
  <div
    class="s-text-block__container"
    {% if request.visual_preview_mode %}
      style="padding: 50px 0;"
    {% endif %}
  >
    <div class="s-text-block__content">
      {% assign title_desktop = section.settings.title %}
      {% assign title_mobile = section.settings.title_mobile | default: title_desktop %}

      {% if title_desktop != blank %}
        <div
          class="s-text-block__title s-text-block__title--desktop"
          {% if request.visual_preview_mode %}
            style="text-align: center; margin-bottom: 12px; font-size: 48px;"
          {% endif %}
        >
          {{ title_desktop }}
        </div>
      {% endif %}

      {% if title_mobile != blank %}
        <div class="s-text-block__title s-text-block__title--mobile">
          {{ title_mobile }}
        </div>
      {% endif %}

      {% assign description_desktop = section.settings.description %}
      {% assign description_mobile = section.settings.description_mobile | default: description_desktop %}

      {% if description_desktop != blank %}
        <div
          class="s-text-block__description s-text-block__description--desktop"
          {% if request.visual_preview_mode %}
            style="text-align: center; font-size: 30px;"
          {% endif %}
        >
          {{ description_desktop }}
        </div>
      {% endif %}

      {% if description_mobile != blank %}
        <div class="s-text-block__description s-text-block__description--mobile">
          {{ description_mobile }}
        </div>
      {% endif %}

      {% if section.settings.byline != blank %}
        <p class="s-text-block__byline">
          {{ section.settings.byline }}
        </p>
      {% endif %}
    </div>
  </div>
</s-text-block>

{% schema %}
{
