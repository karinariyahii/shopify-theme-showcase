{{ 'section-text-block.css' | asset_url | stylesheet_tag }}

{% style %}
  {% if section.settings.title_font_select_mobile == 'shopify' %}
    {{ section.settings.title_font_picker_mobile | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.title_font_select_desktop == 'shopify' %}
    {{ section.settings.title_font_picker_desktop | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.description_font_select_mobile == 'shopify' %}
    {{ section.settings.description_font_picker_mobile | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.description_font_select_desktop == 'shopify' %}
    {{ section.settings.description_font_picker_desktop | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.byline_font_select_mobile == 'shopify' %}
    {{ section.settings.byline_font_picker_mobile | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.byline_font_select_desktop == 'shopify' %}
    {{ section.settings.byline_font_picker_desktop | font_face: font_display: 'swap' }}
  {% endif %}

  {% if section.settings.is_max_width %}
    #shopify-section-{{ section.id }} .s-text-block__container {
      max-width: {{ section.settings.max_width | append: 'px'}};
      margin: 0 auto;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .s-text-block {
    padding-top: {{ section.settings.margin_top_mobile | append: 'px' }};
    padding-bottom: {{ section.settings.margin_bottom_mobile | append: 'px' }};
    background-color: {{ section.settings.background_color_mobile }};
  }

  #shopify-section-{{ section.id }} .s-text-block__container {
    padding-top: {{ section.settings.padding_top_mobile | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-text-block__title :where(p, h1, h2, h3, h4, h5, h6) {
    {% if section.settings.title_font_select_mobile == 'shopify' %}
      font-family: {{ section.settings.title_font_picker_mobile.family }}, {{ section.settings.title_font_picker_mobile.fallback_families | default: 'sans-serif' }};
    {% else %}
      font-family: var(--font-{{ section.settings.title_font_select_mobile }});
    {% endif %}
    font-weight: {{ section.settings.title_font_weight_mobile }};
    font-size: {{ section.settings.title_font_size_mobile | append: 'px' }};
    color: {{ section.settings.title_color_mobile }};
    letter-spacing: {{ section.settings.title_letter_spacing_mobile | append: 'px' }};
    line-height: {{ section.settings.title_line_height_mobile | append: '%' }};
  }

  #shopify-section-{{ section.id }} .s-text-block__title {
    text-align: {{ section.settings.title_align_mobile }};
    margin-bottom: {{ section.settings.title_margin_bottom_mobile | append: 'px' }};
    {% if section.settings.title_max_width_mobile > 0 %}
      max-width: {{ section.settings.title_max_width_mobile | append: '%' }};
      {% case section.settings.title_align_mobile %}
        {% when 'left' %}
          margin-left: 0;
          margin-right: auto;
        {% when 'right' %}
          margin-left: auto;
          margin-right: 0;
        {% else %}
          margin: 0 auto;
      {% endcase %}
    {% endif %}
  }

  #shopify-section-{{ section.id }} .s-text-block__description :where(p, h1, h2, h3, h4, h5, h6) {
    {% if section.settings.description_font_select_mobile == 'shopify' %}
      font-family: {{ section.settings.description_font_picker_mobile.family }}, {{ section.settings.description_font_picker_mobile.fallback_families | default: 'sans-serif' }};
    {% else %}
      font-family: var(--font-{{ section.settings.description_font_select_mobile }});
    {% endif %}
    font-weight: {{ section.settings.description_font_weight_mobile }};
    font-size: {{ section.settings.description_font_size_mobile | append: 'px' }};
    color: {{ section.settings.description_color_mobile }};
    letter-spacing: {{ section.settings.description_letter_spacing_mobile | append: 'px' }};
    line-height: {{ section.settings.description_line_height_mobile | append: '%' }};
  }

  #shopify-section-{{ section.id }} .s-text-block__description {
    text-align: {{ section.settings.description_align_mobile }};
    margin-bottom: {{ section.settings.description_margin_bottom_mobile | append: 'px' }};
    {% if section.settings.description_max_width_mobile > 0 %}
      max-width: {{ section.settings.description_max_width_mobile | append: '%' }};
      {% case section.settings.description_align_mobile %}
        {% when 'left' %}
          margin-left: 0;
          margin-right: auto;
        {% when 'right' %}
          margin-left: auto;
          margin-right: 0;
        {% else %}
          margin: 0 auto;
      {% endcase %}
    {% endif %}
  }

  #shopify-section-{{ section.id }} .s-text-block__byline {
    {% if section.settings.byline_font_select_mobile == 'shopify' %}
      font-family: {{ section.settings.byline_font_picker_mobile.family }}, {{ section.settings.byline_font_picker_mobile.fallback_families | default: 'sans-serif' }};
    {% else %}
      font-family: var(--font-{{ section.settings.byline_font_select_mobile }});
    {% endif %}
    font-weight: {{ section.settings.byline_font_weight_mobile }};
    font-size: {{ section.settings.byline_font_size_mobile | append: 'px' }};
    color: {{ section.settings.byline_color_mobile }};
    text-align: {{ section.settings.byline_align_mobile }};
    letter-spacing: {{ section.settings.byline_letter_spacing_mobile | append: 'px' }};
    line-height: {{ section.settings.byline_line_height_mobile | append: '%' }};
    margin-bottom: {{ section.settings.byline_margin_bottom_mobile | append: 'px' }};
  }

  @media (min-width: 768px) {
