{{ 'section-grid-banner.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .s-grid-banner {
    background-color: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .s-grid-banner__inner {
    padding-top: {{ section.settings.section_padding_top_mobile | append: 'px' }};
    padding-bottom: {{ section.settings.section_padding_bottom_mobile | append: 'px' }};
    margin-top: {{ section.settings.section_margin_top_mobile | append: 'px' }};
    margin-bottom: {{ section.settings.section_margin_bottom_mobile | append: 'px' }};
  }

  {% if section.settings.custom_aspect_ratio_mobile != blank %}
    #shopify-section-{{ section.id }} .s-grid-banner__background {
      aspect-ratio: {{ section.settings.custom_aspect_ratio_mobile | strip }};
      width: 100%;
      height: auto;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .s-grid-banner__content {
    background-color: {{ section.settings.content_background_color }};
    padding: {{ section.settings.content_box_padding_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-grid-banner__title-wrapper {
    justify-content: {{ section.settings.title_align_mobile }};
    text-align: {{ section.settings.title_align_mobile | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-grid-banner__title {
    font-size: {{ section.settings.title_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.title_font_weight_mobile }};
    color: {{ section.settings.title_color_mobile }};
    text-transform: {{ section.settings.title_text_transform_mobile }};
    font-style: {{ section.settings.title_italic_mobile | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.title_underline_mobile | replace: 'true', 'underline' | replace: 'false', 'none' }};
    font-family: var(--font-{{ section.settings.title_font_select }});
    {% if section.settings.title_max_width_mobile > 0 %}
      max-width: {{ section.settings.title_max_width_mobile | append: 'px' }};
    {% endif %}
  }

  #shopify-section-{{ section.id }} .s-grid-banner__subtitle-wrapper {
    justify-content: {{ section.settings.subtitle_align_mobile }};
    text-align: {{ section.settings.subtitle_align_mobile | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-grid-banner__subtitle {
    font-size: {{ section.settings.subtitle_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.subtitle_font_weight_mobile }};
    color: {{ section.settings.subtitle_color_mobile }};
    text-transform: {{ section.settings.subtitle_text_transform_mobile }};
    font-style: {{ section.settings.subtitle_italic_mobile | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.subtitle_underline_mobile | replace: 'true', 'underline' | replace: 'false', 'none' }};
    font-family: var(--font-{{ section.settings.subtitle_font_select }});
    {% if section.settings.subtitle_max_width_mobile > 0 %}
      max-width: {{ section.settings.subtitle_max_width_mobile | append: 'px' }};
    {% endif %}
  }

  #shopify-section-{{ section.id }} .s-grid-banner__link-wrapper {
    justify-content: {{ section.settings.link_align }};
    text-align: {{ section.settings.link_align | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-grid-banner__link, .s-grid-banner__text {
    font-size: {{ section.settings.link_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.link_font_weight }};
    color: {{ section.settings.link_color }};
  }

  #shopify-section-{{ section.id }} .s-grid-banner__link {
    text-transform: {{ section.settings.link_text_transform }};
    font-style: {{ section.settings.link_is_italic | replace: 'true', 'italic' | replace: 'false', 'normal' }};
  }

  {% if section.settings.link_is_underline %}
    #shopify-section-{{ section.id }} .s-grid-banner__link::after {
      background-color: {{section.settings.link_underline_color}};
    }
  {% endif %}

  #shopify-section-{{ section.id }} .s-grid-banner__link:hover {
    color: {{ section.settings.link_color_hover }};
  }

  @media screen and (min-width: 768px) {
    {% if section.settings.custom_aspect_ratio_tablet != blank %}
      #shopify-section-{{ section.id }} .s-grid-banner__background,
      #shopify-section-{{ section.id }} .s-grid-banner__content {
        aspect-ratio: {{ section.settings.custom_aspect_ratio_tablet | strip }};
        width: 100%;
        height: auto;
      }
    {% endif %}
  }

  @media screen and (min-width: 920px) {
    #shopify-section-{{ section.id }} .s-grid-banner__inner {
      padding-top: {{ section.settings.section_padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.section_padding_bottom | append: 'px' }};
      margin-top: {{ section.settings.section_margin_top | append: 'px' }};
      margin-bottom: {{ section.settings.section_margin_bottom | append: 'px' }};
    }

    {% if section.settings.custom_aspect_ratio_desktop != blank %}
      #shopify-section-{{ section.id }} .s-grid-banner__background,
      #shopify-section-{{ section.id }} .s-grid-banner__content {
        aspect-ratio: {{ section.settings.custom_aspect_ratio_desktop | strip }};
        width: 100%;
        height: auto;
      }
    {% endif %}

    #shopify-section-{{ section.id }} .s-grid-banner__content {
      padding: {{ section.settings.content_box_padding | append: 'px' }};
    }

    #shopify-section-{{ section.id }} .s-grid-banner__title-wrapper {
      justify-content: {{ section.settings.title_align_desktop }};
      text-align: {{ section.settings.title_align_desktop | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
    }

    #shopify-section-{{ section.id }} .s-grid-banner__title {
      font-size: {{ section.settings.title_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.title_font_weight_desktop }};
      font-style: {{ section.settings.title_italic_desktop | replace: 'true', 'italic' | replace: 'false', 'normal' }};
      text-decoration: {{ section.settings.title_underline_desktop | replace: 'true', 'underline' | replace: 'false', 'none' }};
      text-transform: {{ section.settings.title_text_transform_desktop }};
      color: {{ section.settings.title_color_desktop }};
      {% if section.settings.title_max_width_desktop > 0 %}
        max-width: {{ section.settings.title_max_width_desktop | append: 'px' }};
        {% else %}
        max-width: unset;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .s-grid-banner__subtitle-wrapper {
      justify-content: {{ section.settings.subtitle_align_desktop }};
      text-align: {{ section.settings.subtitle_align_desktop | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
    }

    #shopify-section-{{ section.id }} .s-grid-banner__subtitle {
      font-size: {{ section.settings.subtitle_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.subtitle_font_weight_desktop }};
      font-style: {{ section.settings.subtitle_italic_desktop | replace: 'true', 'italic' | replace: 'false', 'normal' }};
      text-decoration: {{ section.settings.subtitle_underline_desktop | replace: 'true', 'underline' | replace: 'false', 'none' }};
      text-transform: {{ section.settings.subtitle_text_transform_desktop }};
      color: {{ section.settings.subtitle_color_desktop }};
      {% if section.settings.subtitle_max_width_desktop > 0 %}
        max-width: {{ section.settings.subtitle_max_width_desktop | append: 'px' }};
        {% else %}
        max-width: unset;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .s-grid-banner__link, .s-grid-banner__text {
      font-size: {{ section.settings.link_font_size_desktop | append: 'px' }};
    }
  }
{% endstyle %}

<script src="{{ 'section-grid-banner.js' | asset_url }}" defer></script>
<script src="{{ 'lazy-video.js' | asset_url }}" defer></script>

{% liquid
  assign title = section.settings.title
  assign subtitle = section.settings.subtitle
  assign link_url = section.settings.link_url
  assign link_text = section.settings.link_text
%}

<s-grid-banner
  class="s-grid-banner"
>
  <div
    class="
      s-grid-banner__inner
      {% if section.settings.reverse_content_desktop %}s-grid-banner__inner--reverse-desktop{% endif %}
      {% if section.settings.reverse_content_mobile %}s-grid-banner__inner--reverse-mobile{% endif %}
    "
  >
    <div class="s-grid-banner__content">
      <div class="s-grid-banner__content-inner">
        {% if title != blank %}
          <div class="s-grid-banner__title-wrapper">
            <h2 class="s-grid-banner__title">{{ title }}</h2>
          </div>
        {% endif %}

        {% if subtitle != blank %}
          <div class="s-grid-banner__subtitle-wrapper">
            <p class="s-grid-banner__subtitle">
              {{ subtitle }}
            </p>
          </div>
        {% endif %}

        {% if link_text != blank %}
          {% if link_url != blank %}
            <div class="s-grid-banner__link-wrapper">
              <a class="s-grid-banner__link" href="{{ link_url }}">{{ link_text }}</a>
            </div>
          {% else %}
            <div class="s-grid-banner__link-wrapper">
              <p class="s-grid-banner__text">{{ link_text }}</p>
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>

    <div class="s-grid-banner__background">
      {% if section.settings.enable_swatches %}
        <swiper-container
          class="s-grid-banner__swatches js-grid-banner__swatches"
          id="s-grid-banner__swatches--{{ section.id }}"
          slides-per-view="auto"
          grab-cursor="false"
          pagination="false"
          navigation="false"
        >
          {% for block in section.blocks %}
            <swiper-slide
              class="s-grid-banner__swatches-slide js-grid-banner__swatches-slide"
              style="background-color: {{ block.settings.swatch_color }};"
            >
            </swiper-slide>
          {% endfor %}
        </swiper-container>
      {% endif %}
      <swiper-container
        slides-per-view="1"
        {% if section.settings.enable_swatches %}
        speed="0"
        {% endif %}
        loop="true"
        grab-cursor="false"
        pagination="false"
        navigation="false"
        thumbs-swiper="#s-grid-banner__swatches--{{ section.id }}"
        class="s-grid-banner__slider js-grid-banner__slider"
        initial-slide="{{ section.settings.initial_slide | minus: 1 }}"
      >
        {% for block in section.blocks %}
          {% liquid
            assign image_desktop = block.settings.banner_image_desktop
            assign image_mobile = block.settings.banner_image_mobile | default: image_desktop

            assign video_webm_desktop = block.settings.banner_video_desktop_url
            assign video_webm_mobile = block.settings.banner_video_mobile_url | default: video_webm_desktop

            assign video_file_desktop = block.settings.banner_video_desktop
            assign video_file_mobile = block.settings.banner_video_mobile | default: video_file_desktop

            assign video_mp4_desktop = ''
            if video_file_desktop.sources != blank
              assign video_mp4_desktop = video_file_desktop.sources | where: 'format', 'mp4' | first
              assign video_mp4_desktop = video_mp4_desktop.url
            endif

            assign video_mp4_mobile = ''
            if video_file_mobile.sources != blank
              assign video_mp4_mobile = video_file_mobile.sources | where: 'format', 'mp4' | first
              assign video_mp4_mobile = video_mp4_mobile.url
            endif
          %}
          <swiper-slide class="s-grid-banner__slide">
            {% capture media_content %}
              {% case block.settings.media_type %}
                {% when 'image' %}
                  {% if image_mobile != blank %}
                    {% render 'image-lazy', image: image_mobile, class: 's-grid-banner__background-img s-grid-banner__background-img--mobile' %}
                  {% endif %}
                  {% if image_desktop != blank %}
                    {% render 'image-lazy', image: image_desktop, class: 's-grid-banner__background-img s-grid-banner__background-img--desktop' %}
                  {% endif %}
        
                {% when 'video' %}
                  {% render 'lazy-video',
                    baseClass: 's-grid-banner',
                    videoMobileWebm: video_webm_mobile,
                    videoDesktopWebm: video_webm_desktop,
                    videoMobileMP4: video_mp4_mobile,
                    videoDesktopMP4: video_mp4_desktop,
                    previewImageMobile: image_mobile | default: video_file_mobile.preview_image,
                    previewImageDesktop: image_desktop | default: video_file_desktop.preview_image,
                    autoplay: true,
                    muted: true,
                    loop: true,
                    controls: false,
                    preload: 'metadata'
                  %}
              {% endcase %}
            {% endcapture %}
        
            {% if block.settings.background_url != blank %}
              <a class="s-grid-banner__media-content" href="{{ block.settings.background_url }}">{{ media_content }}</a>
            {% else %}
              <div class="s-grid-banner__slide">{{ media_content }}</div>
            {% endif %}
          </swiper-slide>
        {% endfor %}
      </swiper-container>
    </div>
  </div>
</s-grid-banner>

{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#282828"
    },
    {
      "type": "color",
      "id": "content_background_color",
      "label": "Content Background Color",
      "default": "#F6F5F0"
    },
    {
      "type": "range",
      "id": "content_box_padding",
      "label": "Content Box Padding (Desktop)",
      "min": 0,
      "max": 150,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_box_padding_mobile",
      "label": "Content Box Padding (Mobile)",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "reverse_content_desktop",
      "label": "Reverse Content (Desktop)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "reverse_content_mobile",
      "label": "Reverse Content (Mobile)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_swatches",
      "label": "Enable swatches",
      "default": true,
      "info": "Enables image switching on swatch hover"
    },
    {
      "type": "number",
      "id": "initial_slide",
      "label": "Inital slide",
      "default": 1,
      "info": "If the number exceeds the total blocks, the last slide will be shown."
    },
    {
      "type": "header",
      "content": "Section Margins"
    },
    {
      "type": "range",
      "id": "section_margin_top",
      "label": "Margin Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
