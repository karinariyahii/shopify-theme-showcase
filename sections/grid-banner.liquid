      "min": 0,
      "max": 200,
      "step": 2,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "range",
