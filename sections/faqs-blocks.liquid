{{ 'section-faqs-blocks.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .s-faqs-blocks {
    background-color: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .s-faqs-blocks__container {
  	padding-top: {{ section.settings.padding_top_mobile | append: 'px' }};
  	padding-bottom: {{ section.settings.padding_bottom_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-faqs-blocks__block-title {
    font-family: {{ section.settings.title_font_family }};
    font-size: {{ section.settings.title_font_size_m | append: 'px' }};
    font-weight: {{ section.settings.title_font_weight_m }};
    color: {{ section.settings.title_color_m }};
    text-transform: {{ section.settings.title_text_transform_m }};
    font-style: {% if section.settings.title_italic_m %}italic{% else %}normal{% endif %};
    text-align: {{ section.settings.title_align_m }};
  }

  #shopify-section-{{ section.id }} .s-faqs-blocks__faq-question {
    font-size: {{ section.settings.faq_question_font_size_m | append: 'px' }};
    font-weight: {{ section.settings.faq_question_font_weight_m }};
    color: {{ section.settings.faq_question_color_m }};
    text-transform: {{ section.settings.faq_question_text_transform_m }};
    font-style: {% if section.settings.faq_question_italic_m %}italic{% else %}normal{% endif %};
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .s-faqs-blocks__container {
       padding-top: {{ section.settings.padding_top_desktop | append: 'px' }};
       padding-bottom: {{ section.settings.padding_bottom_desktop | append: 'px' }};
     }


    #shopify-section-{{ section.id }} .s-faqs-blocks__block-title {
      font-size: {{ section.settings.title_font_size | append: 'px' }};
      font-weight: {{ section.settings.title_font_weight }};
      color: {{ section.settings.title_color }};
      text-transform: {{ section.settings.title_text_transform }};
      font-style: {% if section.settings.title_italic %}italic{% else %}normal{% endif %};
      text-align: {{ section.settings.title_align }};
    }

    #shopify-section-{{ section.id }} .s-faqs-blocks__faq-question {
      font-size: {{ section.settings.faq_question_font_size | append: 'px' }};
      font-weight: {{ section.settings.faq_question_font_weight }};
      color: {{ section.settings.faq_question_color }};
      text-transform: {{ section.settings.faq_question_text_transform }};
      font-style: {% if section.settings.faq_question_italic %}italic{% else %}normal{% endif %};
    }
  }
{% endstyle %}

{% if section.blocks.size > 0 %}
  <s-faqs-blocks class="s-faqs-blocks">
    <div class="s-faqs-blocks__container{% if section.settings.enable_container %} is-container{% endif %}">
      <div class="s-faqs-blocks__wrapper">
        {% for block in section.blocks %}
          {% if forloop.first or forloop.index == 4 %}
            <div class="s-faqs-blocks__column">
          {% endif %}
          <div class="s-faqs-blocks__block">
            {% liquid
              assign faqs_category = block.settings.faqs_metaobject
              assign faqs_list = faqs_category.category_items.value
            %}
            {% if faqs_category != blank %}
              <h2 class="s-faqs-blocks__block-title">
                {{ faqs_category.category_title }}
              </h2>
              <div class="s-faqs-blocks__faqs-list">
                {% for faq in faqs_list %}
                  <a href="{{ faq.system.url  }}" class="s-faqs-blocks__faq-item">
                    <h3 class="s-faqs-blocks__faq-question">
                      {{ faq.question }}
                    </h3>

                    <span class="s-faqs-blocks__faq-arrow">
                      {% render 'icon-arrow-right' %}
                    </span>
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </div>

          {% if forloop.last or forloop.index == 3 %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </s-faqs-blocks>
{% endif %}

