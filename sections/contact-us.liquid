<script src="{{ 'section-contact-us.js' | asset_url }}" defer></script>

<s-contact-us class="s-contact-us">
  <div class="s-contact-us__container">
    <div class="s-contact-us__wrapper">
      {% form 'contact', class: 's-contact-us__form js-contact-us__form', novalidate: 'novalidate' %}
        {% if section.settings.title != blank %}
          <h1 class="s-contact-us__title">
            {{ section.settings.title }}
          </h1>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="s-contact-us__description">
            {{ section.settings.description }}
          </div>
        {% endif %}
        <div class="s-contact-us__content">
          {% comment %} Full Name {% endcomment %}
          <div class="s-contact-us__input-wrapper s-contact-us__input-wrapper--fullname js-contact-us__input-wrapper">
            <input
              id="fullname"
              class="s-contact-us__input js-contact-us__input"
              name="contact[full_name]"
              type="text"
              value="
                {%- if customer -%}
                  {{- customer.name -}}
                {%- endif -%}
              "
            >
            <label class="s-contact-us__label" for="fullname">
              {{- 'sections.contact-us.placeholders.full_name' | t -}}
            </label>

            <p class="s-contact-us__input-error js-contact-us__input-error">
              {{ 'sections.contact-us.errors.full_name' | t }}
            </p>
          </div>

          {% comment %} Email {% endcomment %}
          <div class="s-contact-us__input-wrapper s-contact-us__input-wrapper--email js-contact-us__input-wrapper">
            <input
              id="email"
              class="s-contact-us__input js-contact-us__input"
              autocapitalize="off"
              autocomplete="off"
              name="contact[email]"
              spellcheck="false"
              type="email"
              value="
                {%- if form.email -%}
                  {{- form.email -}}
                {%- elsif customer -%}
                  {{- customer.email -}}
                {%- endif -%}
              "
            >
            <label class="s-contact-us__label" for="email">
              {{- 'sections.contact-us.placeholders.email' | t -}}
            </label>
            <p class="s-contact-us__input-error">{{ 'sections.contact-us.errors.email' | t }}</p>
          </div>

          {% comment %} Subject {% endcomment %}
          <div class="s-contact-us__input-wrapper s-contact-us__input-wrapper--subject js-contact-us__input-wrapper">
            <input
              id="subject"
              class="s-contact-us__input js-contact-us__input"
              name="contact[subject]"
              type="text"
              value="{% if form.subject %}{{ form.subject }}{% endif %}"
            >

            <label class="s-contact-us__label" for="subject">
              {{- 'sections.contact-us.placeholders.subject' | t -}}
            </label>

            <p class="s-contact-us__input-error js-contact-us__input-error">
              {{ 'sections.contact-us.errors.subject' | t }}
            </p>
          </div>

          {% comment %} Order Number {% endcomment %}
          <div class="s-contact-us__input-wrapper s-contact-us__input-wrapper--order-number js-contact-us__input-wrapper">
            <input
              id="order_number"
              class="s-contact-us__input js-contact-us__input"
              name="contact[order_number]"
              type="text"
              value="{% if form.order_number %}{{ form.order_number }}{% endif %}"
            >

            <label class="s-contact-us__label" for="order_number">
              {{- 'sections.contact-us.placeholders.order_number' | t -}}
            </label>
          </div>

          {% comment %} Message {% endcomment %}
          <div class="s-contact-us__input-wrapper s-contact-us__input-wrapper--message js-contact-us__input-wrapper">
            <textarea
              id="message"
              class="s-contact-us__textarea js-contact-us__textarea"
              name="contact[body]"
              rows="3"
            >
              {%- if form.body -%}
                {{- form.body -}}
              {%- endif -%}
            </textarea>

            <label class="s-contact-us__label" for="message">
              {{- 'sections.contact-us.placeholders.message' | t -}}
            </label>

            <div class="s-contact-us__textarea-wrapper">
              <p class="s-contact-us__textarea-error js-contact-us__textarea-error">
                {{ 'sections.contact-us.errors.message' | t }}
              </p>
            </div>
          </div>

          <div class="s-contact-us__input-wrapper s-contact-us__input-wrapper--submit js-contact-us__input-wrapper">
            <button
              type="submit"
              class="s-contact-us__submit js-contact-us__submit"
            >
              {{ 'sections.contact-us.placeholders.send' | t }}
            </button>

            <p class="s-contact-us__form-error js-contact-us__form-error">
              {{ 'sections.contact-us.errors.form' | t }}
            </p>

            {% if form.posted_successfully? %}
              <p class="s-contact-us__form-success js-contact-us__form-success">
                {{ 'sections.contact-us.post_success' | t }}
              </p>
            {% endif %}
          </div>
        </div>
      {% endform %}

      <div class="s-contact-us__additional-info">
        {% if section.settings.customer_support_info != blank and section.settings.customer_support_title != blank %}
          <div class="s-contact-us__block">
            <h5 class="s-contact-us__block-title">
              {{ section.settings.customer_support_title }}
            </h5>

            <div class="s-contact-us__block-content">
              {{ section.settings.customer_support_info }}
            </div>
          </div>
        {% endif %}

        {% if section.settings.address_info != blank and section.settings.address_title != blank %}
          <div class="s-contact-us__block">
            <h5 class="s-contact-us__block-title">
              {{ section.settings.address_title }}
            </h5>

            <div class="s-contact-us__block-content">
              {{ section.settings.address_info }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</s-contact-us>

