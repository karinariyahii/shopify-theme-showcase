{{ 'section-two-column.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .s-two-column__inner {
    background-color: {{ section.settings.background_color }};
  	padding-top: {{ section.settings.section_padding_top_mobile | append: 'px' }};
    padding-bottom: {{ section.settings.section_padding_bottom_mobile | append: 'px' }};
    margin-top: {{ section.settings.section_margin_top_mobile | append: 'px' }};
    margin-bottom: {{ section.settings.section_margin_bottom_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-two-column__content {
    background-color: {{ section.settings.content_background_color }};
    padding: {{ section.settings.content_box_padding_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-two-column__title-wrapper {
    justify-content: {{ section.settings.title_align_mobile }};
    text-align: {{ section.settings.title_align_mobile | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-two-column__title {
    font-size: {{ section.settings.title_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.title_font_weight_mobile }};
    color: {{ section.settings.title_color_mobile }};
    text-transform: {{ section.settings.title_text_transform_mobile }};
    font-style: {{ section.settings.title_italic_mobile | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.title_underline_mobile | replace: 'true', 'underline' | replace: 'false', 'none' }};
    font-family: var(--font-{{ section.settings.title_font_select }});
    {% if section.settings.title_max_width_mobile > 0 %}
      max-width: {{ section.settings.title_max_width_mobile | append: 'px' }};
    {% endif %}
  }

  #shopify-section-{{ section.id }} .s-two-column__subtitle-wrapper {
    justify-content: {{ section.settings.subtitle_align_mobile }};
    text-align: {{ section.settings.subtitle_align_mobile | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-two-column__subtitle {
    font-size: {{ section.settings.subtitle_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.subtitle_font_weight_mobile }};
    color: {{ section.settings.subtitle_color_mobile }};
    text-transform: {{ section.settings.subtitle_text_transform_mobile }};
    font-style: {{ section.settings.subtitle_italic_mobile | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.subtitle_underline_mobile | replace: 'true', 'underline' | replace: 'false', 'none' }};
    font-family: var(--font-{{ section.settings.subtitle_font_select }});
    {% if section.settings.subtitle_max_width_mobile > 0 %}
      max-width: {{ section.settings.subtitle_max_width_mobile | append: 'px' }};
    {% endif %}
  }

  #shopify-section-{{ section.id }} .s-two-column__link-wrapper {
    justify-content: {{ section.settings.link_align }};
    text-align: {{ section.settings.link_align | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-two-column__link, .s-two-column__text {
    font-size: {{ section.settings.link_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.link_font_weight }};
    color: {{ section.settings.link_color }};
  }

  #shopify-section-{{ section.id }} .s-two-column__link {
    text-transform: {{ section.settings.link_text_transform }};
    font-style: {{ section.settings.link_is_italic | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.link_is_underline | replace: 'true', 'underline' | replace: 'false', 'none' }};
  }

  #shopify-section-{{ section.id }} .s-two-column__link:hover {
    color: {{ section.settings.link_color_hover }};
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .s-two-column__inner {
      padding-top: {{ section.settings.section_padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.section_padding_bottom | append: 'px' }};
      margin-top: {{ section.settings.section_margin_top | append: 'px' }};
      margin-bottom: {{ section.settings.section_margin_bottom | append: 'px' }};
    }

    #shopify-section-{{ section.id }} .s-two-column__content {
      padding: {{ section.settings.content_box_padding | append: 'px' }};
    }

    #shopify-section-{{ section.id }} .s-two-column__title-wrapper {
      justify-content: {{ section.settings.title_align_desktop }};
      text-align: {{ section.settings.title_align_desktop | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
    }

    #shopify-section-{{ section.id }} .s-two-column__title {
      font-size: {{ section.settings.title_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.title_font_weight_desktop }};
      font-style: {{ section.settings.title_italic_desktop | replace: 'true', 'italic' | replace: 'false', 'normal' }};
      text-decoration: {{ section.settings.title_underline_desktop | replace: 'true', 'underline' | replace: 'false', 'none' }};
      text-transform: {{ section.settings.title_text_transform_desktop }};
      color: {{ section.settings.title_color_desktop }};
      {% if section.settings.title_max_width_desktop > 0 %}
        max-width: {{ section.settings.title_max_width_desktop | append: 'px' }};
        {% else %}
        max-width: unset;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .s-two-column__subtitle-wrapper {
      justify-content: {{ section.settings.subtitle_align_desktop }};
      text-align: {{ section.settings.subtitle_align_desktop | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
    }

    #shopify-section-{{ section.id }} .s-two-column__subtitle {
      font-size: {{ section.settings.subtitle_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.subtitle_font_weight_desktop }};
      font-style: {{ section.settings.subtitle_italic_desktop | replace: 'true', 'italic' | replace: 'false', 'normal' }};
      text-decoration: {{ section.settings.subtitle_underline_desktop | replace: 'true', 'underline' | replace: 'false', 'none' }};
      text-transform: {{ section.settings.subtitle_text_transform_desktop }};
      color: {{ section.settings.subtitle_color_desktop }};
      {% if section.settings.subtitle_max_width_desktop > 0 %}
        max-width: {{ section.settings.subtitle_max_width_desktop | append: 'px' }};
        {% else %}
        max-width: unset;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .s-two-column__link, .s-two-column__text {
      font-size: {{ section.settings.link_font_size_desktop | append: 'px' }};
    }
  }
{% endstyle %}

<script src="{{ 'lazy-video.js' | asset_url }}" defer></script>

{% liquid
  assign title = section.settings.title
  assign subtitle = section.settings.subtitle
  assign link_url = section.settings.link_url
  assign link_text = section.settings.link_text

  if section.settings.background_type == 'image'
    assign promo_desktop = section.settings.banner_image_desktop
    assign promo_mobile = section.settings.banner_image_mobile | default: promo_desktop
  elsif section.settings.background_type == 'video'
    assign video_webm_desktop = section.settings.banner_video_desktop_url
    assign video_webm_mobile = section.settings.banner_video_mobile_url | default: video_webm_desktop

    assign video_file_desktop = section.settings.banner_video_desktop
    assign video_file_mobile = section.settings.banner_video_mobile | default: video_file_desktop

    assign video_mp4_desktop = ''
    if video_file_desktop.sources != blank
      assign video_mp4_desktop = video_file_desktop.sources | where: 'format', 'mp4' | first
      assign video_mp4_desktop = video_mp4_desktop.url
    endif

    assign video_mp4_mobile = ''
    if video_file_mobile.sources != blank
      assign video_mp4_mobile = video_file_mobile.sources | where: 'format', 'mp4' | first
      assign video_mp4_mobile = video_mp4_mobile.url
    endif
  endif
%}

<div class="s-two-column">
  <div
    class="
      s-two-column__inner
      {% if section.settings.reverse_content_desktop %}s-two-column__inner--reverse-desktop{% endif %}
      {% if section.settings.reverse_content_mobile %}s-two-column__inner--reverse-mobile{% endif %}
    "
  >
    <div class="s-two-column__content">
      {% if title != blank %}
        <div class="s-two-column__title-wrapper">
          <h2
            class="s-two-column__title"
            {% if request.visual_preview_mode %}
              style="font-size: 48px;"
            {% endif %}
          >
            {{ title }}
          </h2>
        </div>
      {% endif %}

      {% if subtitle != blank %}
        <div class="s-two-column__subtitle-wrapper">
          <div
            class="s-two-column__subtitle"
            {% if request.visual_preview_mode %}
              style="font-size: 40px;"
            {% endif %}
          >
            {{ subtitle }}
          </div>
        </div>
      {% endif %}

      {% if link_text != blank %}
        {% if link_url != blank %}
          <div class="s-two-column__link-wrapper">
            <a class="s-two-column__link" href="{{ link_url }}">{{ link_text }}</a>
          </div>
        {% else %}
          <div class="s-two-column__link-wrapper">
            <p class="s-two-column__text">{{ link_text }}</p>
          </div>
        {% endif %}
      {% endif %}
    </div>

    {%- capture column_background -%}
      {% if section.settings.background_type == 'image' %}
        {% if promo_mobile != blank %}
          {% render 'image-lazy',
            image: promo_mobile,
            class: 's-two-column__background-img s-two-column__background-img--mobile'
          %}
        {% endif %}
        {% if promo_desktop != blank %}
          {% render 'image-lazy',
            image: promo_desktop,
            class: 's-two-column__background-img s-two-column__background-img--desktop'
          %}
        {% endif %}
      {% elsif section.settings.background_type == 'video' %}
        <div class="s-two-column__background-video">
          {% render 'lazy-video',
            baseClass: 's-two-column',
            videoMobileWebm: video_webm_mobile,
            videoDesktopWebm: video_webm_desktop,
            videoMobileMP4: video_mp4_mobile,
            videoDesktopMP4: video_mp4_desktop,
            autoplay: true,
            muted: true,
            loop: true,
            controls: false,
            preload: 'metadata'
          %}
        </div>
      {% endif %}
    {%- endcapture -%}

    {% if section.settings.background_url != blank %}
      <a class="s-two-column__background" href="{{ section.settings.background_url }}">
        {{ column_background }}
      </a>
    {% else %}
      <div class="s-two-column__background">
        {{ column_background }}
      </div>
    {% endif %}
  </div>
</div>

