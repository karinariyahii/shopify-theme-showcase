{{ 'section-support-search.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .s-support-search {
    background-color: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .s-support-search {
  	margin-top: {{ section.settings.margin_top_mobile | append: 'px' }};
  	margin-bottom: {{ section.settings.margin_bottom_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-support-search__container {
  	padding-top: {{ section.settings.padding_top_mobile | append: 'px' }};
  	padding-bottom: {{ section.settings.padding_bottom_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-support-search__title {
    font-size: {{ section.settings.title_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.title_font_weight_mobile }};
    font-style: {{ section.settings.title_italic_mobile | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.title_underline_mobile | replace: 'true', 'underline' | replace: 'false', 'none' }};
    text-transform: {{ section.settings.title_text_transform_mobile }};
    color: {{ section.settings.title_color_mobile }};
    {% if section.settings.title_max_width_mobile > 0 %}
      max-width: {{ section.settings.title_max_width_mobile | append: 'px' }};
    {% endif %}
    font-family: {{ section.settings.title_font_family }};
    text-align: {{ section.settings.title_align_mobile | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
    align-self: {{ section.settings.title_align_mobile | replace: 'flex-start', 'start' | replace: 'center', 'center' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-support-search__input {
    font-size: {{ section.settings.input_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.input_font_weight_mobile }};
    color: {{ section.settings.input_color_mobile }};
    border-color: rgba({{ section.settings.input_border_color_mobile.red }}, {{ section.settings.input_border_color_mobile.green }}, {{ section.settings.input_border_color_mobile.blue }}, {{ section.settings.bc_opacity_mobile }});
  }

  #shopify-section-{{ section.id }} .s-support-search__input::placeholder {
    color: rgba({{ section.settings.input_placeholder_color_mobile.red }}, {{ section.settings.input_placeholder_color_mobile.green }}, {{ section.settings.input_placeholder_color_mobile.blue }}, {{ section.settings.ph_opacity_mobile }});
  }

  #shopify-section-{{ section.id }} .s-support-search__button {
    font-size: {{ section.settings.button_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.button_font_weight_mobile }};
    color: {{ section.settings.button_color_mobile }};
    background-color: {{ section.settings.button_bg_color_mobile }};
    border: 1px solid {{ section.settings.button_border_color_mobile }};
  }



  #shopify-section-{{ section.id }} .s-support-search__wrapper {
    gap: {{ section.settings.input_button_gap | append: 'px' }};
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .s-support-search {
      margin-top: {{ section.settings.margin_top_desktop | append: 'px' }};
      margin-bottom: {{ section.settings.margin_bottom_desktop | append: 'px' }};
    }
     
    #shopify-section-{{ section.id }} .s-support-search__container {
      padding-top: {{ section.settings.padding_top_desktop | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom_desktop | append: 'px' }};
    }

    #shopify-section-{{ section.id }} .s-support-search__title {
      font-size: {{ section.settings.title_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.title_font_weight_desktop }};
      font-style: {{ section.settings.title_italic_desktop | replace: 'true', 'italic' | replace: 'false', 'normal' }};
      text-decoration: {{ section.settings.title_underline_desktop | replace: 'true', 'underline' | replace: 'false', 'none' }};
      text-transform: {{ section.settings.title_text_transform_desktop }};
      color: {{ section.settings.title_color_desktop }};
      {% if section.settings.title_max_width_desktop > 0 %}
        max-width: {{ section.settings.title_max_width_desktop | append: 'px' }};
      {% else %}
        max-width: unset;
      {% endif %}
      font-family: {{ section.settings.title_font_family }};
      text-align: {{ section.settings.title_align_desktop | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
      align-self: {{ section.settings.title_align_desktop | replace: 'flex-start', 'start' | replace: 'center', 'center' | replace: 'flex-end', 'end' }};
    }

    #shopify-section-{{ section.id }} .s-support-search__input {
      font-size: {{ section.settings.input_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.input_font_weight_desktop }};
      color: {{ section.settings.input_color_desktop }};
      border-color: rgba({{ section.settings.input_border_color_desktop.red }}, {{ section.settings.input_border_color_desktop.green }}, {{ section.settings.input_border_color_desktop.blue }}, {{ section.settings.bc_opacity_desktop }});
    }

    #shopify-section-{{ section.id }} .s-support-search__input::placeholder {
      color: rgba({{ section.settings.input_placeholder_color_desktop.red }}, {{ section.settings.input_placeholder_color_desktop.green }}, {{ section.settings.input_placeholder_color_desktop.blue }}, {{ section.settings.ph_opacity_desktop }});
    }

    #shopify-section-{{ section.id }} .s-support-search__input:hover {
      border-color: {{ section.settings.input_border_hover_color_desktop }};
    }

    #shopify-section-{{ section.id }} .s-support-search__input:focus {
      border-color: {{ section.settings.input_border_focus_color_desktop }};
    }

    #shopify-section-{{ section.id }} .s-support-search__button {
      font-size: {{ section.settings.button_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.button_font_weight_desktop }};
      color: {{ section.settings.button_color_desktop }};
      background-color: {{ section.settings.button_bg_color_desktop }};
      border: 1px solid {{ section.settings.button_border_color_desktop }};
    }

    #shopify-section-{{ section.id }} .s-support-search__button:hover {
      color: {{ section.settings.button_hover_color_desktop }};
      background-color: {{ section.settings.button_hover_bg_color_desktop }};
      border-color: {{ section.settings.button_hover_border_color_desktop }};
    }
  }
{% endstyle %}

<script src="{{ 'section-support-search.js' | asset_url }}" defer></script>

<s-support-search class="s-support-search" data-search-page-url="{{ section.settings.search_page }}">
  {% liquid
    assign bg_image_desktop = section.settings.background_image_desktop
    assign bg_image_mobile = section.settings.background_image_mobile | default: bg_image_desktop
  %}
  {% if bg_image_desktop != blank %}
    <div class="s-support-search__bg-wrapper">
      {% render 'image-lazy',
        image: bg_image_desktop,
        class: 's-support-search__bg-image s-support-search__bg-image--desktop'
      %}
      {% render 'image-lazy',
        image: bg_image_mobile,
        class: 's-support-search__bg-image s-support-search__bg-image--mobile'
      %}
    </div>
  {% endif %}
  <div class="s-support-search__container">
    {% if section.settings.title != blank %}
      <h1
        class="s-support-search__title"
      >
        {{ section.settings.title }}
      </h1>
    {% endif %}
    <div class="s-support-search__wrapper">
      <input
        type="title"
        class="s-support-search__input js-support-search__input{% if bg_image_desktop != blank %} bg-blur{% endif %}"
        placeholder="{{ 'sections.support_search.search_placeholder' | t }}"
      >
      <button class="s-support-search__button js-support-search__button" type="submit">
        {{ 'sections.support_search.search_button' | t }}
      </button>
    </div>
  </div>
</s-support-search>

