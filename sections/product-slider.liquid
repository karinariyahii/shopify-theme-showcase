{% style %}
  #shopify-section-{{ section.id }} .s-product-slider {
    background-color: {{ section.settings.background_color }};
  	padding-top: {{ section.settings.section_padding_top_mobile | append: 'px' }};
    padding-bottom: {{ section.settings.section_padding_bottom_mobile | append: 'px' }};
    margin-top: {{ section.settings.section_margin_top_mobile | append: 'px' }};
    margin-bottom: {{ section.settings.section_margin_bottom_mobile | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-product-slider__container {
    background-color: {{ section.settings.container_bg_color }};
    {% if section.settings.enable_container %}
      max-width: {{ section.settings.container_width | append: 'px' }};
    {% endif %}
  }


  #shopify-section-{{ section.id }} .s-product-slider__heading {
    padding-bottom: {{ section.settings.heading_bottom_padding_m | append: 'px' }};
  }

  #shopify-section-{{ section.id }} .s-product-slider__title-wrapper {
    justify-content: {{ section.settings.title_align_mobile }};
    text-align: {{ section.settings.title_align_mobile | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-product-slider__title {
    font-size: {{ section.settings.title_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.title_font_weight_mobile }};
    color: {{ section.settings.title_color_mobile }};
    text-transform: {{ section.settings.title_text_transform_mobile }};
    font-style: {{ section.settings.title_italic_mobile | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.title_underline_mobile | replace: 'true', 'underline' | replace: 'false', 'none' }};
    font-family: var(--font-{{ section.settings.title_font_select }});
    {% if section.settings.title_max_width_mobile > 0 %}
      max-width: {{ section.settings.title_max_width_mobile | append: 'px' }};
    {% endif %}
  }

  #shopify-section-{{ section.id }} .s-product-slider__subtitle-wrapper {
    justify-content: {{ section.settings.subtitle_align_mobile }};
    text-align: {{ section.settings.subtitle_align_mobile | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
  }

  #shopify-section-{{ section.id }} .s-product-slider__subtitle {
    font-size: {{ section.settings.subtitle_font_size_mobile | append: 'px' }};
    font-weight: {{ section.settings.subtitle_font_weight_mobile }};
    color: {{ section.settings.subtitle_color_mobile }};
    text-transform: {{ section.settings.subtitle_text_transform_mobile }};
    font-style: {{ section.settings.subtitle_italic_mobile | replace: 'true', 'italic' | replace: 'false', 'normal' }};
    text-decoration: {{ section.settings.subtitle_underline_mobile | replace: 'true', 'underline' | replace: 'false', 'none' }};
    font-family: var(--font-{{ section.settings.subtitle_font_select }});
    {% if section.settings.subtitle_max_width_mobile > 0 %}
      max-width: {{ section.settings.subtitle_max_width_mobile | append: 'px' }};
    {% endif %}
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .s-product-slider {
      padding-top: {{ section.settings.section_padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.section_padding_bottom | append: 'px' }};
      margin-top: {{ section.settings.section_margin_top | append: 'px' }};
      margin-bottom: {{ section.settings.section_margin_bottom | append: 'px' }};
    }

    #shopify-section-{{ section.id }} .s-product-slider__heading {
      padding-bottom: {{ section.settings.heading_bottom_padding_d | append: 'px' }};
    }

    #shopify-section-{{ section.id }} .s-product-slider__title-wrapper {
      justify-content: {{ section.settings.title_align_desktop }};
      text-align: {{ section.settings.title_align_desktop | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
    }

    #shopify-section-{{ section.id }} .s-product-slider__title {
      font-size: {{ section.settings.title_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.title_font_weight_desktop }};
      font-style: {{ section.settings.title_italic_desktop | replace: 'true', 'italic' | replace: 'false', 'normal' }};
      text-decoration: {{ section.settings.title_underline_desktop | replace: 'true', 'underline' | replace: 'false', 'none' }};
      text-transform: {{ section.settings.title_text_transform_desktop }};
      color: {{ section.settings.title_color_desktop }};
      {% if section.settings.title_max_width_desktop > 0 %}
        max-width: {{ section.settings.title_max_width_desktop | append: 'px' }};
        {% else %}
        max-width: unset;
      {% endif %}
    }

    #shopify-section-{{ section.id }} .s-product-slider__subtitle-wrapper {
      justify-content: {{ section.settings.subtitle_align_desktop }};
      text-align: {{ section.settings.subtitle_align_desktop | replace: 'flex-start', 'start' | replace: 'flex-end', 'end' }};
    }

    #shopify-section-{{ section.id }} .s-product-slider__subtitle {
      font-size: {{ section.settings.subtitle_font_size_desktop | append: 'px' }};
      font-weight: {{ section.settings.subtitle_font_weight_desktop }};
      font-style: {{ section.settings.subtitle_italic_desktop | replace: 'true', 'italic' | replace: 'false', 'normal' }};
      text-decoration: {{ section.settings.subtitle_underline_desktop | replace: 'true', 'underline' | replace: 'false', 'none' }};
      text-transform: {{ section.settings.subtitle_text_transform_desktop }};
      color: {{ section.settings.subtitle_color_desktop }};
      {% if section.settings.subtitle_max_width_desktop > 0 %}
        max-width: {{ section.settings.subtitle_max_width_desktop | append: 'px' }};
        {% else %}
        max-width: unset;
      {% endif %}
    }
  }
{% endstyle %}

{% liquid
  assign title = section.settings.title
  assign subtitle = section.settings.subtitle
  assign products = blank

  case section.settings.products_source
    when 'collection'
      assign products = section.settings.collection.products
    when 'products_list'
      assign products = section.settings.product_list
    when 'recommendations'
      assign products = product.metafields.custom.recommended_products.value | default: recommendations.products
  endcase
%}

{% if products != blank or product != blank %}
  <s-product-slider
    data-products-source="{{ section.settings.products_source }}"
    data-product-id="{{ product.id }}"
    data-products-limit="{{ section.settings.products_limit }}"
    data-section-id="{{ section.id }}"
    data-recommendations-type="{{ section.settings.recommendations_type }}"
    class="s-product-slider"
  >
    <div class="s-product-slider__container">
      <div class="s-product-slider__heading">
        {% if title != blank %}
          <div class="s-product-slider__title-wrapper">
            <h2 class="s-product-slider__title">{{ title }}</h2>
          </div>
        {% endif %}
        {% if subtitle != blank %}
          <div class="s-product-slider__subtitle-wrapper">
            <p class="s-product-slider__subtitle s-product-slider__subtitle--desktop">{{ subtitle }}</p>
          </div>
        {% endif %}
      </div>
      <div class="s-product-slider__grid js-product-slider__grid">
        <swiper-container
          style="
            --pagination-padding-top: {{ section.settings.slider_pagination_padding_top_d | append: 'px' }};
            --bullets_color: {{ section.settings.slider_bullets_color_d }};
            --bullets_border_color: {{ section.settings.slider_bullets_border_color_d }};
            --bullets_active_color: {{ section.settings.slider_bullets_active_color_d }};
            --fraction_color: {{ section.settings.slider_fraction_color_d }};
          "
          class="s-product-slider__slider s-product-slider__slider--desktop js-product-slider__slider"
          space-between="{{ section.settings.space_between_d }}"
          slides-per-view="{{ section.settings.slides_per_view_d }}"
          {% if section.settings.enable_slider_loop_d %}
            loop="true"
          {% endif %}
          {% if section.settings.enable_slider_autoplay_d %}
            autoplay="true"
            autoplay-delay="{{ section.settings.slider_autoplay_delay_d }}"
          {% endif %}
          {% if section.settings.enable_slider_pagination_d %}
            pagination="true"
            pagination-type="{{ section.settings.slider_pagination_type_d }}"
            pagination-clickable="{{ section.settings.slider_enable_pagination_clickable_d }}"
          {% endif %}
          speed="{{ section.settings.slider_change_speed_d }}"
        >
          {% for product in products limit: section.settings.products_limit %}
            <swiper-slide class="s-product-slider__slide">
              {% render 'product-card',
                product: product,
                media_type: 'image',
                display_wishlist: section.settings.card_display_wishlist_d,
                display_sold_out_badge: section.settings.card_display_sold_out_badge_d,
                display_tag_badge: section.settings.card_display_tag_badge_d,
                display_discount_badge: section.settings.card_display_discount_badge_d,
                display_low_stock_badge: section.settings.card_display_low_stock_badge_d,
                display_simple_color_swatch: section.settings.card_display_simple_color_swatch_d,
                display_add_to_cart: section.settings.card_display_add_to_cart_d,
                display_product_type: section.settings.card_display_product_type_d
              %}
            </swiper-slide>
          {% endfor %}
        </swiper-container>

        <swiper-container
          style="
            --pagination-padding-top: {{ section.settings.slider_pagination_padding_top_m | append: 'px' }};
            --bullets_color: {{ section.settings.slider_bullets_color_m }};
            --bullets_border_color: {{ section.settings.slider_bullets_border_color_m }};
            --bullets_active_color: {{ section.settings.slider_bullets_active_color_m }};
            --fraction_color: {{ section.settings.slider_fraction_color_m }};
          "
          class="s-product-slider__slider s-product-slider__slider--mobile js-product-slider__slider"
          space-between="{{ section.settings.space_between_m }}"
          slides-per-view="{{ section.settings.slides_per_view_m }}"
          {% if section.settings.enable_slider_loop_m %}
            loop="true"
          {% endif %}
          {% if section.settings.enable_slider_autoplay_m %}
            autoplay="true"
            autoplay-delay="{{ section.settings.slider_autoplay_delay_m }}"
          {% endif %}
          {% if section.settings.enable_slider_pagination_m %}
            pagination="true"
            pagination-type="{{ section.settings.slider_pagination_type_m }}"
            pagination-clickable="{{ section.settings.slider_enable_pagination_clickable_m }}"
          {% endif %}
          speed="{{ section.settings.slider_change_speed_m }}"
        >
          {% for product in products limit: section.settings.products_limit %}
            <swiper-slide class="s-product-slider__slide">
              {% render 'product-card',
                product: product,
                media_type: 'image',
                display_wishlist: section.settings.card_display_wishlist_m,
                display_sold_out_badge: section.settings.card_display_sold_out_badge_m,
                display_tag_badge: section.settings.card_display_tag_badge_m,
                display_discount_badge: section.settings.card_display_discount_badge_m,
                display_low_stock_badge: section.settings.card_display_low_stock_badge_m,
                display_simple_color_swatch: section.settings.card_display_simple_color_swatch_m,
                display_add_to_cart: section.settings.card_display_add_to_cart_m,
                display_product_type: section.settings.card_display_product_type_m
              %}
            </swiper-slide>
          {% endfor %}
        </swiper-container>
      </div>
    </div>
  </s-product-slider>
{% endif %}

